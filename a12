import pandas as pd

# Load dataset
data = pd.read_csv("iris.csv")

# Column names (adjust if needed)
features = data.columns[:-1]
label = data.columns[-1]

# Species list
species_list = data[label].unique()

print("Basic Statistical Details for Iris Dataset\n")

for species in species_list:
    print("\n===================================")
    print("Species:", species)
    print("===================================")
    
    subset = data[data[label] == species]
    
    # Mean
    print("\nMean:\n", subset[features].mean())
    
    # Standard Deviation
    print("\nStandard Deviation:\n", subset[features].std())
    
    # Percentiles
    print("\nPercentiles (25%, 50%, 75%):\n", subset[features].quantile([0.25, 0.5, 0.75]))



