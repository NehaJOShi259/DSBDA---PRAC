import pandas as pd

# Load dataset
data = pd.read_csv("wine.csv")

# Assume last column is categorical (class/quality/type)
categorical_col = data.columns[-1]

# Numeric columns
numeric_cols = data.select_dtypes(include='number').columns

# Group by categorical variable
grouped_stats = data.groupby(categorical_col)[numeric_cols].agg(['mean', 'median', 'min', 'max', 'std'])

print("Grouped Summary Statistics:\n")
print(grouped_stats)

